@PACKAGE_INIT@

# ExasimConfig.cmake.in — installed CMake config for Exasim.
#
# Downstream consumer:
#
#     find_package(Exasim REQUIRED)
#     add_executable(my_solver main.cpp)
#     target_link_libraries(my_solver PRIVATE
#         Exasim::headers Exasim::cpumpiprelib)
#
# The package exports:
#   - Exasim::headers      (INTERFACE include target)
#   - Exasim::cpulib       (libcpuEXASIM.a, when built)
#   - Exasim::cpumpilib    (libcpumpiEXASIM.a, when built)
#   - Exasim::cpuprelib    (libcpupreEXASIM.a, when built)
#   - Exasim::cpumpiprelib (libcpumpipreEXASIM.a, when built)
#   - Exasim::gpulib       (libgpuEXASIM.a, when built)
#   - Exasim::gpumpilib    (libgpumpiEXASIM.a, when built)
#   - Exasim::gpuprelib    (libgpupreEXASIM.a, when built)
#   - Exasim::gpumpiprelib (libgpumpipreEXASIM.a, when built)
#
# Each exported library target carries the transitive link interface of its
# solver variant. Kokkos is always required; MPI is required whenever any
# exported MPI library variant is present in the package.

include(CMakeFindDependencyMacro)

set(_EXASIM_KOKKOS_DIR "@Kokkos_DIR@")
if(NOT TARGET Kokkos::kokkos)
  if(EXISTS "${_EXASIM_KOKKOS_DIR}/KokkosConfig.cmake")
    find_package(Kokkos REQUIRED CONFIG
      PATHS "${_EXASIM_KOKKOS_DIR}"
      NO_DEFAULT_PATH)
  elseif(EXISTS "${_EXASIM_KOKKOS_DIR}/lib/cmake/Kokkos/KokkosConfig.cmake")
    find_package(Kokkos REQUIRED CONFIG
      PATHS "${_EXASIM_KOKKOS_DIR}/lib/cmake/Kokkos"
      NO_DEFAULT_PATH)
  else()
    find_dependency(Kokkos REQUIRED)
  endif()
endif()
if(@EXASIM_PACKAGE_HAS_MPI@)
  find_dependency(MPI REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/ExasimTargets.cmake")

check_required_components(Exasim)
